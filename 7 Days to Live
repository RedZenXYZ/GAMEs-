end

local IGNORED = {}
local TPC = false
addToggleState("Teleport Collect", function(state)
	TPC = state
	local IsTP = false
	local root = CHAR:FindFirstChild("HumanoidRootPart")
	local oldCF = root.CFrame
	
	while TPC do
		for _,obj in COLLECTABLE[2]:GetChildren() do
			if not TPC then print("break") break end
			if table.find(IGNORED, obj.Name) then print("checked") continue end
			
			print("Work")
			local main = obj:FindFirstChild("main") or obj:FindFirstChild("Handle") or nil
			if main then
				print("Collecting")
				IsTP = true
				COLLECT(main)
			end
		end
		task.wait(1)
		print("TP Back")
		if IsTP then
			IsTP = false
			root.CFrame = oldCF
		end
	end
end)

