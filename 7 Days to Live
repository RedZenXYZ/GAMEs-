createPage("Items")
addToggle("Collect Aura", function()
	for _,t in COLLECTABLE do
		for _,obj in t:GetChildren() do
			local main = obj:FindFirstChild("main") or obj:FindFirstChild("Handle") or nil
			if main then
				local dist = LOC:DistanceFromCharacter(main.Position)
				local prox = main:FindFirstChildOfClass("ProximityPrompt")
				
				if prox and dist < 15 then
					fireproximityprompt(prox)
				end
			end
		end
	end
end)

addToggle("Auto Scrap", function()
	local IsTP2 = false
	local root = CHAR:FindFirstChild("HumanoidRootPart")
	local oldCF = root.CFrame
	
	local supply = game:GetService("Workspace"):FindFirstChild("supply_crate")
	if supply then
		IsTP2 = true
		COLLECT(supply.hey)
	end
	for _,obj in SCRAPS:GetChildren() do
		if not obj.Name == "scrap" then continue end
		local main = obj:FindFirstChild("defaultMaterial10")
		if main then
			IsTP2 = true
			COLLECT(main)
		end
	end
	task.wait(0.5)
	if IsTP2 then
		IsTP2 = false
		root.CFrame = oldCF
	end
end)

if CAST and POINT then
	addToggle("Auto Fish", function()
